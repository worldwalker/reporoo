# Required: create with Telegram's @BotFather.
TELEGRAM_BOT_TOKEN=

# Comma-separated numeric IDs. An empty allowlist blocks all chats.
TELEGRAM_ALLOWED_CHAT_IDS=-1001234567890

# Comma-separated numeric user IDs allowed to manage the registry and use /details.
TELEGRAM_ADMIN_USER_IDS=

# Local state. Keep these paths private and backed up as appropriate.
REGISTRY_DATABASE=./data/registry.sqlite
REPOSITORY_CACHE_DIR=./data/repositories

# Resource and abuse controls.
MAX_REPOSITORIES_PER_QUESTION=5
REPOSITORY_SYNC_TTL_SECONDS=300
RATE_LIMIT_PER_MINUTE=6

# Optional. Empty uses the Codex SDK default model.
CODEX_MODEL=

# Optional. When set, users can select Claude with /model claude.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-5
